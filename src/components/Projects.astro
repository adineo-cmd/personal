---
import { projects } from '../pages/data/content.js';

const featuredProjects = projects.filter(p => p.featured).slice(0, 3);
---

<section id="projects" class="py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl font-bold mb-3 text-zinc-200">Selected Work</h2>
    <p class="text-zinc-500 text-sm mb-10">
      A collection of projects showcasing expertise in AI/ML and full-stack development.
    </p>
    
    <div class="space-y-6">
      {featuredProjects.map((project, idx) => {
        const primaryUrl = project.githubUrl || project.liveUrl || null;
        return (
          <div 
            class="bg-zinc-900 border border-zinc-800 rounded p-6 hover:border-zinc-700 transition-all group"
          >
            <div class="flex items-start gap-2 mb-3 flex-wrap">
              {primaryUrl ? (
                <a
                  href={primaryUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-base font-semibold text-zinc-200 group-hover:text-zinc-100 hover:underline inline-flex items-start"
                >
                  {project.title}
                </a>
              ) : (
                <h3 class="text-base font-semibold text-zinc-200">
                  {project.title}
                </h3>
              )}
              {project.githubUrl && (
                <a 
                  href={project.githubUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex-shrink-0 flex items-center p-1 rounded hover:bg-zinc-800 hover:scale-110 transition-all"
                  aria-label={`View ${project.title} on GitHub`}
                >
                  <svg 
                    xmlns="http://www.w3.org/2000/svg" 
                    width="20" 
                    height="20" 
                    viewBox="0 0 24 24" 
                    fill="currentColor"
                    class="github-icon text-zinc-500 hover:text-zinc-300 opacity-80 hover:opacity-100"
                  >
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111 1.022-.254 1.022-.567v-2.474c-3.338.724-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.956-.262 1.983-.397 3.003-.397s2.047.135 3.006.397c2.291-1.552 3.297-1.23 3.297-1.23.652 1.652.241 2.873.118 3.176.767.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823.899.823 1.82v2.683c0 .313.424.677 1.023.567 4.765-1.587 8.207-6.084 8.207-11.387 0-6.627-5.373-12-12-12z"/>
                  </svg>
                </a>
              )}
              {project.liveUrl && (
                <a 
                  href={project.liveUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex-shrink-0 flex items-center p-1 rounded hover:bg-zinc-800 hover:scale-110 transition-all"
                  aria-label={`Visit live site for ${project.title}`}
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-zinc-500 hover:text-zinc-300 opacity-80 hover:opacity-100">
                    <circle cx="12" cy="12" r="10" /><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                  </svg>
                </a>
              )}
            </div>
            <p class="text-zinc-400 text-sm mb-4 leading-relaxed">
              {project.description}
            </p>
            <div class="flex flex-wrap gap-2">
              {project.tags?.map(tag => (
                <span 
                  class="px-3 py-1 bg-zinc-800 text-zinc-500 rounded text-xs"
                >
                  {tag}
                </span>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>

  <style>
    .github-icon {
      transition: fill 0.2s ease;
    }
    .github-icon:hover {
      fill: rgb(228, 228, 228); /* text-zinc-200 */
    }
  </style>
</section>
