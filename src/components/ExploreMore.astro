---
const links = [
  { label: 'blogs, thoughts', path: 'writings', id: 'writings' },
  { label: 'projects, experiments', path: 'projects', id: 'projects' },
  { label: 'photographs', path: 'photos', id: 'photos' }, // 🌼 third spot!
  { label: 'books, reads', path: 'library', id: 'library' },
  { label: 'notes & ideas', path: 'notes', id: 'notes' },
  { label: 'goals, wishes', path: 'list100', id: 'list100' },
  { label: 'exercise routine', path: 'exercise', id: 'exercise' },
  { label: 'daily routine', path: 'routine', id: 'routine' },
  { label: 'computer & gear', path: 'gear', id: 'gear' },
  { label: 'cool links', path: 'links', id: 'links' },
  { label: 'progress, achievements', path: 'timeline', id: 'timeline' },
  { label: 'family tree, lineage', path: 'family-tree', id: 'family-tree' },
  { label: 'miscellaneous', id: 'misc', path: 'misc' }
];
---

<section
  id="explore"
  class="py-24 px-6 bg-zinc-950 relative overflow-hidden"
  style={{
    backgroundImage: `url('/images/debian_grey_swirl.webp')`,
    backgroundSize: 'cover',
    backgroundPosition: 'center',
    backgroundRepeat: 'no-repeat',
    backgroundColor: '#0f0f0f',
  }}
>
  {/* Semi-transparent overlay */}
  <div class="absolute inset-0 bg-black/60"></div>

  <div class="max-w-4xl mx-auto relative z-10">
    {/* Left-aligned heading & subheading */}
    <h2 class="text-4xl font-bold mb-2 text-zinc-100 text-left">
      Explore
    </h2>
    <p class="text-zinc-500 text-sm mb-12 text-left">
      projects, writings, books, timeline, family, goals, gear, notes, links, fitness, photos, and misc
    </p>

    {/* Left-aligned links */}
    <div class="space-y-6 text-left">
      {links.map((link, idx) => (
        <div key={idx} class="text-lg text-zinc-500 leading-relaxed hover:text-zinc-400 transition-colors">
          <span>{link.label}</span>
          <span class="mx-3">–</span>
          <a
            href={`/${link.path}`}
            class="text-zinc-300 underline hover:text-zinc-100 transition-colors"
          >
            /{link.path}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>