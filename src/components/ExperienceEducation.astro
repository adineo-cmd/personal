---
import { certifications, education } from '../pages/data/content.js';
---

<!-- Hidden radio buttons for tab switching -->
<input type="radio" id="cert-tab-radio" name="exp-edu-tabs" class="hidden" checked />
<input type="radio" id="edu-tab-radio" name="exp-edu-tabs" class="hidden" />

<section
  id="experience-education"
  class="py-20 px-6 relative overflow-hidden"
  style="background-image: url('/images/rubiks-cube.webp'); background-size: cover; background-position: center; background-repeat: no-repeat; background-color: #0f0f0f;"
>
  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-black/70"></div>

  <div class="max-w-5xl mx-auto relative z-10">
    <!-- Tabs -->
    <div class="flex gap-12 mb-12 border-b border-zinc-800">
      <label
        for="cert-tab-radio"
        class="pb-4 text-xl font-medium transition-colors relative cursor-pointer text-zinc-500 hover:text-zinc-300"
      >
        Certifications
        <span class="cert-underline absolute bottom-0 left-0 right-0 h-0.5 bg-zinc-100 opacity-0"></span>
      </label>
      <label
        for="edu-tab-radio"
        class="pb-4 text-xl font-medium transition-colors relative cursor-pointer text-zinc-500 hover:text-zinc-300"
      >
        Education
        <span class="edu-underline absolute bottom-0 left-0 right-0 h-0.5 bg-zinc-100 opacity-0"></span>
      </label>
    </div>

    <!-- Content -->
    <div class="space-y-8">
      <!-- Certifications Cards -->
      <div class="cert-content">
        {certifications.map((cert, idx) => (
          <div class="relative pl-8 border-l-2 border-zinc-800 mb-8" key={idx}>
            <div class="absolute left-0 top-2 w-3 h-3 rounded-full bg-white -translate-x-[7px]"></div>
            <div class="pb-8">
              <div class="flex justify-between items-start flex-wrap gap-2 mb-3">
                <h3 class="text-xl font-semibold text-zinc-100">{cert.title}</h3>
                <span class="text-sm text-zinc-500 flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12 6 12 12 16 14" />
                  </svg>
                  {cert.period}
                </span>
              </div>
              <p class="text-zinc-400 text-base mb-4">{cert.issuer}</p>
              <p class="text-zinc-500 text-sm leading-relaxed">{cert.description}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Education Cards -->
      <div class="edu-content">
        {education.map((edu, idx) => (
          <div class="relative pl-8 border-l-2 border-zinc-800 mb-8" key={idx}>
            <div class="absolute left-0 top-2 w-3 h-3 rounded-full bg-white -translate-x-[7px]"></div>
            <div class="pb-8">
              <div class="flex justify-between items-start flex-wrap gap-2 mb-2">
                <h3 class="text-xl font-semibold text-zinc-100">{edu.degree}</h3>
                <span class="text-sm text-zinc-500 flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12 6 12 12 16 14" />
                  </svg>
                  {edu.period}
                </span>
              </div>
              <p class="text-zinc-400 text-base mb-2">{edu.institution}</p>
              <div class="flex items-center gap-2 mb-4">
                <p class="text-zinc-500 text-sm flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                  {edu.location}
                </p>
              </div>
              <p class="text-zinc-500 text-sm leading-relaxed">{edu.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* Hide both contents by default */
  .cert-content,
  .edu-content {
    display: none;
  }

  /* Certifications active */
  #cert-tab-radio:checked ~ #experience-education .cert-content {
    display: block;
  }
  #cert-tab-radio:checked ~ #experience-education .edu-content {
    display: none;
  }

  /* Education active */
  #edu-tab-radio:checked ~ #experience-education .edu-content {
    display: block;
  }
  #edu-tab-radio:checked ~ #experience-education .cert-content {
    display: none;
  }

  /* Underline control */
  .cert-underline,
  .edu-underline {
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  #cert-tab-radio:checked ~ #experience-education .cert-underline {
    opacity: 1;
  }

  #edu-tab-radio:checked ~ #experience-education .edu-underline {
    opacity: 1;
  }

  /* Text color */
  #cert-tab-radio:checked ~ #experience-education label[for='cert-tab-radio'],
  #edu-tab-radio:checked ~ #experience-education label[for='edu-tab-radio'] {
    color: #f4f4f5; /* text-zinc-100 */
  }

  #cert-tab-radio:checked ~ #experience-education label[for='edu-tab-radio'],
  #edu-tab-radio:checked ~ #experience-education label[for='cert-tab-radio'] {
    color: #71717a; /* text-zinc-500 */
  }
</style>