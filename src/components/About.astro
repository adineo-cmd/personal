---
// src/components/About.astro
import { aboutText, personalInfo } from '../data/content.js';

// Split text by periods and filter out empty strings
const sentences = aboutText
  .split('.')
  .map(s => s.trim())
  .filter(s => s.length > 0);
---

<section
  id="about"
  class="py-20 px-6 relative overflow-hidden"
  style={{
    backgroundImage: `url('/images/gruv-portal-cake.webp')`,
    backgroundSize: 'cover',
    backgroundPosition: 'center',
    backgroundRepeat: 'no-repeat',
    backgroundColor: '#0f0f0f',
  }}
>
  {/* Semi-transparent overlay */}
  <div class="absolute inset-0 bg-black/60"></div>

  {/* Content */}
  <div class="max-w-5xl mx-auto relative z-10">
    <h2 class="text-3xl font-bold mb-8 text-zinc-200">About</h2>
    
    <div class="text-zinc-400 text-base mb-12 leading-relaxed space-y-3">
      {sentences.map((sentence, index) => (
        <p key={index}>
          {sentence}.
        </p>
      ))}
    </div>
  </div>
</section>