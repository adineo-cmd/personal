---
import { personalInfo } from '../pages/data/content.js';
---

<section
  id="contact"
  class="py-20 px-6 relative overflow-hidden"
  style={{
    backgroundImage: `url('/images/orbit.webp')`,
    backgroundSize: 'cover',
    backgroundPosition: 'center',
    backgroundRepeat: 'no-repeat',
    backgroundColor: '#0f0f0f',
  }}
>
  {/* Semi-transparent overlay */}
  <div class="absolute inset-0 bg-black/60"></div>

  <div class="max-w-4xl mx-auto text-center relative z-10">
    <h2 class="text-3xl font-bold mb-6 text-zinc-200">Get in Touch</h2>
    <p class="text-zinc-400 text-base mb-12 max-w-2xl mx-auto leading-relaxed">
      Currently seeking full-time opportunities to leverage my skills in Full-Stack development and AI/ML engineering. Let's connect!
    </p>
    
    <div class="grid md:grid-cols-2 gap-4 mb-10 max-w-3xl mx-auto">
      <a 
        href={`mailto:${personalInfo.email}`}
        class="flex items-center gap-4 p-5 bg-zinc-900 border border-zinc-800 rounded hover:border-zinc-700 transition-all text-left"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-zinc-500">
          <rect x="2" y="4" width="20" height="16" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
        </svg>
        <div>
          <p class="text-xs text-zinc-500 mb-1">Email</p>
          <p class="text-sm text-zinc-300">{personalInfo.email}</p>
        </div>
      </a>
      
      <a 
        href={personalInfo.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-4 p-5 bg-zinc-900 border border-zinc-800 rounded hover:border-zinc-700 transition-all text-left"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-zinc-500">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" /><rect x="2" y="9" width="4" height="12" /><circle cx="4" cy="4" r="2" />
        </svg>
        <div>
          <p class="text-xs text-zinc-500 mb-1">LinkedIn</p>
          <p class="text-sm text-zinc-300">Aditya Yadav</p>
        </div>
      </a>
      
      <a 
        href={personalInfo.github}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-4 p-5 bg-zinc-900 border border-zinc-800 rounded hover:border-zinc-700 transition-all text-left"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-zinc-500">
          <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c2.6-.4 5.5-2 5.5-7 0-1.25-.756-2.453-2-2.972A2.5 2.5 0 0 0 17 2c-1.309 0-2.592.584-3.602 1.202A8.822 8.822 0 0 0 12 2c-1.01 0-2.292.584-3.602 1.202C7.398 2.584 6.115 2 4.806 2a2.5 2.5 0 0 0-.504 4.528c-1.244.519-2 1.722-2 2.972 0 5 2.9 6.6 5.5 7a4.8 4.8 0 0 0-1 3.5v4" /><path d="M9 16c-.333.333-1 .833-2.5 1M16 16c.333.333 1 .833 2.5 1" />
        </svg>
        <div>
          <p class="text-xs text-zinc-500 mb-1">GitHub</p>
          <p class="text-sm text-zinc-300">adineo-cmd</p>
        </div>
      </a>
      
      <a 
        href={personalInfo.leetcode}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-4 p-5 bg-zinc-900 border border-zinc-800 rounded hover:border-zinc-700 transition-all text-left"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-zinc-500">
          <polyline points="12 3 20 7.5 20 16.5 12 21 4 16.5 4 7.5 12 3" /><polyline points="12 12 20 7.5" /><polyline points="12 12 12 21" /><polyline points="12 12 4 7.5" />
        </svg>
        <div>
          <p class="text-xs text-zinc-500 mb-1">LeetCode</p>
          <p class="text-sm text-zinc-300">adineo-cmd</p>
        </div>
      </a>
    </div>

    <a 
      href={`mailto:${personalInfo.email}`}
      class="inline-block px-8 py-3 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 rounded text-sm transition-colors"
    >
      Send a message
    </a>
  </div>
</section>
