---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageNav from '../components/PageNavigation.astro';
import { linksData } from '../data/links';
---

<BaseLayout title="Links | Aditya Yadav" description="All my links and online presences">
  <>
    <PageNav currentPage="links" />

    <div class="min-h-screen bg-[#0f0f0f]">
      <div 
        class="text-zinc-400 py-16 px-6"
        style="font-family: 'Courier New', Courier, monospace;"
      >
        <div class="max-w-5xl mx-auto">
          <h1 class="text-5xl font-serif mb-6 text-zinc-200">Links</h1>
          
          <p class="text-xs text-zinc-500 mb-2">Updated: February 05, 2026</p>
          
          <p class="text-zinc-400 text-sm mb-8 leading-relaxed">
            A curated collection of all my online presences, projects, and resources. 
            Organized by category for easy navigation.
          </p>

          {/* ASCII Art Section */}
          <pre class="text-zinc-500 text-sm mb-8 whitespace-pre font-mono">
{linksData.asciiArt}
          </pre>

          {/* Table of Contents Section */}
          <div class="mb-10">
            <h2 class="text-2xl font-medium text-zinc-200 mb-4">Table of Contents</h2>
            <ol class="list-decimal list-inside space-y-2 pl-4 border-l-2 border-zinc-800/50 py-2">
              {linksData.categories.map((category, catIndex) => (
                <li key={catIndex} class="text-zinc-400 py-1">
                  <a 
                    href={`#category-${catIndex}`} 
                    class="text-zinc-300 hover:text-zinc-100 transition-colors hover:underline"
                  >
                    {category.title}
                  </a>
                </li>
              ))}
            </ol>
          </div>

          {linksData.categories.map((category, catIndex) => (
            <div class="mb-10 border-b border-zinc-800/50 pb-8 last:border-0 last:pb-0" key={catIndex}>
              {/* Anchor point for table of contents */}
              <h2 id={`category-${catIndex}`} class="text-2xl font-medium text-zinc-200 mb-3">{category.title}</h2>
              {category.description && (
                <p class="text-zinc-500 text-sm mb-4 leading-relaxed">
                  {category.description}
                </p>
              )}
              
              {category.links.map((link, linkIndex) => (
                <p key={linkIndex} class="text-zinc-400 mb-1">
                  <a 
                    href={link.url.trim()}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-zinc-300 hover:text-zinc-100 transition-colors hover:underline"
                  >
                    {link.name}
                  </a> - {link.description}
                </p>
              ))}
            </div>
          ))}
        </div>
      </div>

      <div class="border-t border-zinc-800/50 py-6">
        <div class="max-w-5xl mx-auto px-6">
          <a
            href="/"
            class="flex items-center gap-2 text-zinc-500 hover:text-zinc-300 transition-colors text-sm"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="19" y1="12" x2="5" y2="12" /><polyline points="12 19 5 12 12 5" />
            </svg>
            Back to Home
          </a>
        </div>
      </div>
    </div>
  </>
</BaseLayout>