---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Aditya Yadav', description = 'Fullstack Engineer' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#09090b" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-zinc-950 text-zinc-400 antialiased">
    <slot />
  </body>
</html>
